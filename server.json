{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "ai.dinglebear/apprise-rmcp",
  "title": "Apprise RMCP",
  "description": "Rust MCP server and CLI for Apprise notification fan-out across dozens of delivery backends.",
  "version": "0.2.0",
  "websiteUrl": "https://github.com/jmagar/rapprise",
  "repository": {
    "url": "https://github.com/jmagar/rapprise",
    "source": "github",
    "id": "1238227302"
  },
  "icons": [
    {
      "src": "https://avatars.githubusercontent.com/u/38927646?v=4",
      "mimeType": "image/png",
      "sizes": [
        "460x460"
      ],
      "theme": "dark"
    }
  ],
  "packages": [
    {
      "registryType": "npm",
      "registryBaseUrl": "https://registry.npmjs.org",
      "identifier": "apprise-rmcp",
      "version": "0.2.0",
      "runtimeHint": "npx",
      "packageArguments": [
        {
          "type": "positional",
          "value": "mcp",
          "description": "Run Apprise RMCP over stdio.",
          "format": "string",
          "isRequired": true,
          "isSecret": false,
          "isRepeated": false
        }
      ],
      "environmentVariables": [
        {
          "name": "APPRISE_URL",
          "description": "Apprise API server base URL.",
          "format": "string",
          "isRequired": false,
          "isSecret": false,
          "default": "http://localhost:8000",
          "placeholder": "http://localhost:8000"
        },
        {
          "name": "APPRISE_TOKEN",
          "description": "Optional bearer token for protected Apprise API servers.",
          "format": "string",
          "isRequired": false,
          "isSecret": true
        },
        {
          "name": "APPRISE_RMCP_VERSION",
          "description": "Optional GitHub release tag override for the downloaded Apprise RMCP binary.",
          "format": "string",
          "isRequired": false,
          "isSecret": false,
          "placeholder": "v0.1.2"
        },
        {
          "name": "APPRISE_RMCP_REPO",
          "description": "Optional GitHub owner/repo override for release asset downloads.",
          "format": "string",
          "isRequired": false,
          "isSecret": false,
          "default": "jmagar/rapprise",
          "placeholder": "jmagar/rapprise"
        },
        {
          "name": "APPRISE_RMCP_RELEASE_BASE_URL",
          "description": "Optional release download base URL override.",
          "format": "string",
          "isRequired": false,
          "isSecret": false
        },
        {
          "name": "RUST_LOG",
          "description": "Tracing filter for Apprise RMCP logs.",
          "format": "string",
          "isRequired": false,
          "isSecret": false,
          "default": "info",
          "placeholder": "info"
        }
      ],
      "transport": {
        "type": "stdio"
      }
    }
  ],
  "_meta": {
    "io.modelcontextprotocol.registry/publisher-provided": {
      "namespace": "ai.dinglebear",
      "dnsDomain": "dinglebear.ai",
      "distribution": {
        "nodePackage": "apprise-rmcp"
      },
      "buildInfo": {
        "version": "0.2.0",
        "repository": "https://github.com/jmagar/rapprise"
      }
    }
  }
}
