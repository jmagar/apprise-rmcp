# ── Secrets / URLs (go in .env, never config.toml) ───────────────────────────

# Upstream Apprise API server URL (optional; this is the default)
APPRISE_URL=http://localhost:8000

# Optional bearer token for the Apprise API server
APPRISE_TOKEN=
APPRISE_MAX_CONCURRENT_REQUESTS=32
APPRISE_MAX_RESPONSE_BYTES=65536

# Static bearer token for the MCP HTTP server (generate: openssl rand -hex 32)
APPRISE_MCP_TOKEN=

# Google OAuth credentials (only needed when auth_mode=oauth in config.toml)
APPRISE_MCP_AUTH_MODE=bearer
APPRISE_MCP_PUBLIC_URL=
APPRISE_MCP_GOOGLE_CLIENT_ID=
APPRISE_MCP_GOOGLE_CLIENT_SECRET=
APPRISE_MCP_AUTH_ADMIN_EMAIL=
APPRISE_MCP_AUTH_ALLOWED_REDIRECT_URIS=
APPRISE_MCP_AUTH_ALLOWED_EMAILS=
APPRISE_MCP_AUTH_SQLITE_PATH=
APPRISE_MCP_AUTH_KEY_PATH=
APPRISE_MCP_AUTH_ACCESS_TOKEN_TTL_SECS=3600
APPRISE_MCP_AUTH_REFRESH_TOKEN_TTL_SECS=2592000
APPRISE_MCP_AUTH_CODE_TTL_SECS=300
APPRISE_MCP_AUTH_REGISTER_REQUESTS_PER_MINUTE=10
APPRISE_MCP_AUTH_AUTHORIZE_REQUESTS_PER_MINUTE=60
APPRISE_MCP_AUTH_MAX_PENDING_OAUTH_STATES=1024
APPRISE_MCP_DISABLE_STATIC_TOKEN_WITH_OAUTH=true

# Optional HTTP policy overrides
APPRISE_MCP_HOST=0.0.0.0
APPRISE_MCP_PORT=40050
APPRISE_MCP_NO_AUTH=false
APPRISE_MCP_ALLOWED_HOSTS=
APPRISE_MCP_ALLOWED_ORIGINS=

# Docker Compose runtime vars
APPRISE_MCP_VERSION=latest
APPRISE_UID=1000
APPRISE_GID=1000

# Logging
RUST_LOG=info
