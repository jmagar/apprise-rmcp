{
  "name": "apprise-rmcp",
  "version": "0.2.0",
  "description": "Node launcher for the Apprise Rust MCP server and rapprise CLI for multi-backend notifications.",
  "license": "MIT",
  "homepage": "https://github.com/jmagar/rapprise#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jmagar/rapprise.git",
    "directory": "packages/apprise-rmcp"
  },
  "bugs": {
    "url": "https://github.com/jmagar/rapprise/issues"
  },
  "bin": {
    "apprise-rmcp": "bin/rapprise.js",
    "rapprise": "bin/rapprise.js"
  },
  "files": [
    "bin/",
    "lib/",
    "scripts/",
    "README.md",
    "LICENSE*",
    "package.json"
  ],
  "scripts": {
    "prepack": "node scripts/sync-readme.js",
    "postinstall": "node scripts/install.js",
    "test": "node --test",
    "check": "node --check bin/rapprise.js && node --check scripts/install.js && node --check lib/platform.js && node --check scripts/sync-readme.js && node --check scripts/check-package.js && node scripts/check-package.js",
    "prepublishOnly": "node scripts/check-package.js --release"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "rmcp",
    "rust",
    "apprise",
    "notifications",
    "push-notifications",
    "webhooks",
    "homelab",
    "cli",
    "claude-code",
    "codex",
    "gemini",
    "automation",
    "oauth",
    "http-server",
    "stdio"
  ],
  "mcpName": "ai.dinglebear/apprise-rmcp",
  "binaryVersion": "0.2.0",
  "author": {
    "name": "dinglebear.ai",
    "url": "https://dinglebear.ai"
  }
}
